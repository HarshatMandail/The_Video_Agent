# ═══════════════════════════════════════════════════════════════════════════════
# Foxio Video Agent — Environment Configuration
# Copy this file to .env and fill in your credentials.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Agent 1: Azure OpenAI (Required for browser analysis) ───────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_DEPLOYMENT_MINI=gpt-4o-mini

# ─── Agent 2: xAI Grok (Required for video generation) ──────────────────────
XAI_API_KEY=<your-xai-api-key>

# ─── LLM Cost Controls ───────────────────────────────────────────────────────
MAX_TOKENS_PER_REQUEST=8000
MAX_COMPLETION_TOKENS=2048
MAX_COST_PER_SESSION_USD=1.0
LLM_TEMPERATURE=0
ENABLE_LLM_CACHE=true
CACHE_TTL_SECONDS=21600
ENABLE_BUDGET_CHECK=true

# ─── Browser Configuration (Agent 1) ─────────────────────────────────────────
BROWSER_USE_HEADLESS=false
BROWSER_CHANNEL=
NAVIGATION_TIMEOUT_MS=30000
PAGE_LOAD_TIMEOUT_MS=15000
WAIT_FOR_LOGIN_TIMEOUT=300
LOGIN_CHECK_INTERVAL=3
RECORD_CURSOR_METADATA=true

# ─── Security ────────────────────────────────────────────────────────────────
URL_ALLOWLIST=
URL_BLOCKLIST=localhost,127.0.0.1,0.0.0.0,file://,javascript:,data:,chrome://,about:

# ─── Video Pipeline (Agent 2) ────────────────────────────────────────────────
DEFAULT_MODEL=grok-imagine-video
DEFAULT_RESOLUTION=720p
MAX_CLIP_DURATION=8
DRY_RUN=false
SDK_GENERATION_TIMEOUT=600
SDK_POLL_INTERVAL=1.0

# ─── Redis (Agent 2 background queue — optional) ─────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Retry / Resilience ──────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_BASE_DELAY=1.0

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=foxio-video-agent
